---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
const withBase = (path: string) => {
  const cleanBase = base.endsWith('/') ? base.slice(0, -1) : base;
  const cleanPath = path.replace(/^\//, '');
  return `${cleanBase}/${cleanPath}`;
};
---
<BaseLayout title="About / Resume | Portfolio">
  <h1>About / Resume</h1>

  <h2>Bio</h2>
  <p>
    I'm Jorge Alvarez, a Business &amp; Information Systems student at NJIT. My focus is on the
    intersection of technology and business — understanding how systems are built, how organizations
    run, and how software can improve both.
  </p>
  <p>
    I'm drawn to projects that require clear thinking and disciplined execution. I build things
    that are practical, well-documented, and designed to be maintained, not just submitted.
  </p>

  <h2>Strengths and Interests</h2>
  <ul class="clean-list">
    <li>Business systems analysis and process documentation</li>
    <li>Building practical software tools with clear scope and purpose</li>
    <li>Leadership and collaborative project delivery</li>
    <li>Technology strategy and how software decisions affect organizations</li>
    <li>Writing clear documentation and structured specifications</li>
  </ul>

  <h2>Education</h2>
  <ul class="clean-list">
    <li><strong>NJIT</strong> — Business and Information Systems, Expected May 2028</li>
  </ul>

  <h2>Resume</h2>
  <p>
    <a href={withBase('/resume/jorge-alvarez-resume.docx')} target="_blank" rel="noopener noreferrer">Download resume (DOCX) →</a>
  </p>
</BaseLayout>
