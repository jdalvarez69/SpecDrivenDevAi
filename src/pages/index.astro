---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { projects } from '../data/projects';

const featured = projects.filter((p) => p.featured);
const base = import.meta.env.BASE_URL;
const withBase = (path: string) => {
  const cleanBase = base.endsWith('/') ? base.slice(0, -1) : base;
  const cleanPath = path.replace(/^\//, '');
  return `${cleanBase}/${cleanPath}`;
};
---
<BaseLayout title="Home | Portfolio">
  <h1>Hi, I'm Jorge Alvarez</h1>
  <p class="lead">Business &amp; Information Systems student at NJIT focused on building practical software and understanding the systems that make organizations work.</p>
  <p>I approach projects with discipline and clarity — building things that are useful, maintainable, and easy to understand.</p>

  <h2>Selected Projects</h2>
  {featured.map((project) => (
    <ProjectCard project={project} />
  ))}
  <p class="section-gap"><a href={withBase('/projects')}>View all projects →</a></p>

  <h2>Skills</h2>
  <ul class="skills">
    <li><strong>Languages:</strong> JavaScript, Python, HTML, CSS, SQL</li>
    <li><strong>Tools:</strong> Git, GitHub, VS Code, Excel, npm</li>
    <li><strong>Concepts:</strong> Business systems, REST APIs, static site generation, data analysis, process documentation</li>
  </ul>

  <p class="section-gap">
    <a href={withBase('/contact')}>Get in touch →</a>
  </p>
</BaseLayout>

<style>
  .skills {
    list-style: none;
    padding-left: 0;
  }

  .skills li {
    margin-bottom: 0.5rem;
  }
</style>
